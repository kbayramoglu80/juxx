    <style>
        /* Inline styling for btn_3 to bypass any aggressive browser caching issues */
        .btn_3 {
            display: inline-block !important;
            background: #c49b45 !important; /* Premium Gold brand color */
            color: #ffffff !important;
            border: 1px solid #c49b45 !important;
            padding: 14px 35px !important;
            font-size: 14px !important;
            font-weight: 600 !important;
            letter-spacing: 1.5px !important;
            text-transform: uppercase !important;
            border-radius: 50px !important;
            cursor: pointer !important;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1) !important;
            text-align: center !important;
            box-shadow: 0 4px 15px rgba(196, 155, 69, 0.2) !important;
            line-height: 1.5 !important;
            text-decoration: none !important;
        }
        .btn_3:hover {
            background: #b08d4a !important; /* Premium Gold hover color */
            border-color: #b08d4a !important;
            color: #ffffff !important;
            transform: translateY(-2px) !important;
            box-shadow: 0 8px 25px rgba(196, 155, 69, 0.4) !important;
            text-decoration: none !important;
        }
        .btn_3:active {
            transform: translateY(0) !important;
        }
    </style>
</head>
<body class="full-wrapper">
    <!-- ? Preloader Start -->
    <div id="preloader-active">
        <div class="preloader d-flex align-items-center justify-content-center" style="background-color: #ffffff; z-index: 999999;">
            <div class="preloader-inner position-relative text-center">
                <div class="preloader-img">
                    <img src="/assets/img/logo/custom_logo_v2.png" alt="MI DIAMOND" style="max-width: 250px; height: auto; animation: logoPulse 1.2s ease-in-out infinite alternate;">
                </div>
            </div>
        </div>
    </div>
    <style>
        @keyframes logoPulse {
            0% {
                opacity: 0.6;
                transform: scale(0.96);
            }
            100% {
                opacity: 1;
                transform: scale(1.04);
            }
        }

        /* Center the loading preloader logo perfectly on both PC and mobile */
        #preloader-active .preloader {
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            width: 100vw !important;
            height: 100vh !important;
            background-color: #ffffff !important;
            z-index: 999999 !important;
        }

        #preloader-active .preloader-inner {
            position: static !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            width: auto !important;
            height: auto !important;
            text-align: center !important;
        }

        #preloader-active .preloader-img {
            position: static !important;
            transform: none !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            margin: 0 auto !important;
            text-align: center !important;
            padding-top: 0 !important;
        }

        #preloader-active .preloader-img img {
            max-width: 250px !important;
            height: auto !important;
            display: block !important;
            margin: 0 auto !important;
        }

        @media (max-width: 767px) {
            #preloader-active .preloader-img img {
                max-width: 180px !important;
            }
        }
    </style>
