<%- include('partials/head') %>
<%- include('partials/header') %>

<main>
    <section class="login_part" style="padding-top: 100px; padding-bottom: 100px;">
        <div class="container">
            <div class="row align-items-center justify-content-center">
                <div class="col-lg-6 col-md-8">
                    <div class="login_part_form" style="padding: 50px 0;">
                        <div class="login_part_form_iner">
                            <h3>Tekrar Hoş Geldiniz! <br>
                                Lütfen Giriş Yapın</h3>
                            <% if (error) { %>
                                <div class="alert alert-danger"><%= error %></div>
                            <% } %>
                            <form class="row contact_form" action="/login" method="post" novalidate="novalidate">
                                <div class="col-md-12 form-group p_star">
                                    <input type="email" class="form-control" id="email" name="email" value=""
                                        placeholder="E-posta">
                                </div>
                                <div class="col-md-12 form-group p_star">
                                    <input type="password" class="form-control" id="password" name="password" value=""
                                        placeholder="Şifre">
                                </div>
                                <div class="col-md-12 form-group">
                                    <button type="submit" value="submit" class="btn_3">
                                        Giriş Yap
                                    </button>
                                </div>
                                <div class="col-md-12 text-center mt-4">
                                    <a href="/register" style="color: #4a4a4a; font-weight: 500;">Sitemize Yeni Misiniz? <span style="color: #ff3368; font-weight: bold;">Hemen Kayıt Olun</span></a>
                                </div>
                                <div class="col-md-12 text-center mt-3 pt-3 border-top" style="border-color: #eee !important;">
                                    <a href="/checkout" class="btn_3 w-100 text-center" style="background: #fdfaf2; color: #bca374; border: 1px solid #e3d2be; border-radius: 50px; font-weight: 700; letter-spacing: 0.5px; padding: 14px 0; transition: all 0.3s; display: block;" onmouseover="this.style.background='#bca374'; this.style.color='#fff';" onmouseout="this.style.background='#fdfaf2'; this.style.color='#bca374';">Üye Olmadan Devam Et</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
