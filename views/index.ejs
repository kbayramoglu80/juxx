<%- include('partials/head') %>
<%- include('partials/header') %>

<main>
    <style>
        @media (max-width: 991px) {
            .slider-area {
                margin-top: 24px;
            }
        }

        @media (max-width: 767px) {
            .slider-area .single-slider.slider-height {
                min-height: 560px !important;
            }

            .slider-area .hero__caption {
                padding: 0 12px;
            }

            .slider-area .hero__caption h1 {
                font-size: 34px;
                line-height: 1.2;
                margin-bottom: 18px;
            }
        }
    </style>
    <!--? Hero Area Start-->
    <div class="container-fluid">
        <div class="slider-area">
            <div class="slider-active dot-style">
                <% if (typeof heroBanners !== 'undefined' && heroBanners.length > 0) { %>
                    <% heroBanners.forEach(banner => { %>
                        <div class="single-slider hero-overly slider-height d-flex align-items-center" style="background-image: url('<%= banner.imageUrl %>'); background-size: cover; background-position: center;">
                            <div class="container">
                                <div class="row justify-content-center">
                                    <div class="col-xl-8 col-lg-9">
                                        <!-- Hero Caption -->
                                        <div class="hero__caption">
                                            <h1><%- banner.title.replace(/\n/g, '<br>') %></h1>
                                            <a href="<%= banner.link %>" class="btn"><%= banner.subtitle || 'Şimdi Al' %></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <!-- Fallback if no banners -->
                    <div style="cursor: pointer; width: 100%; line-height: 0;" onclick="window.location.href='/shop'">
                        <img src="/assets/img/hero/slider_1.png" alt="Açılışa Özel Kampanya" style="width: 100%; height: auto; display: block;">
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    <!-- End Hero -->
    
<!--? New Arrival Start -->
<div class="new-arrival">
    <div class="container">
        <!-- Section title & Sorting Dropdown -->
        <div class="row justify-content-center mb-40">
            <div class="col-xl-7 col-lg-8 col-md-10 text-center">
                <div class="section-tittle mb-20 wow fadeInUp" data-wow-duration="2s" data-wow-delay=".2s">
                    <h2><%= typeof setting !== 'undefined' ? (setting.newArrivalTitle || 'Yeni Gelenler') : 'Yeni Gelenler' %></h2>
                </div>
                <!-- Premium Sorting Dropdown -->
                <div class="sorting-wrapper wow fadeInUp" data-wow-duration="1.5s" data-wow-delay=".3s" style="margin-top: 15px; margin-bottom: 25px;">
                    <label for="homeProductSort" style="font-size: 11px; font-weight: 600; letter-spacing: 1.5px; color: #c49b45; margin-right: 8px; text-transform: uppercase;">Sıralama:</label>
                    <select id="homeProductSort" style="background-color: #ffffff; color: #1a1a1a; border: 1px solid #c49b45; padding: 6px 18px; border-radius: 20px; font-size: 12px; font-weight: 600; cursor: pointer; outline: none; transition: all 0.3s ease; box-shadow: 0 4px 10px rgba(196, 155, 69, 0.1);">
                        <option value="newest" selected>En Yeniler (Varsayılan)</option>
                        <option value="price-asc">Fiyat: Düşükten Yükseğe</option>
                        <option value="price-desc">Fiyat: Yüksekten Düşüğe</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="premium-grid" id="homeProductGrid">
            <% if (typeof products !== 'undefined' && products.length > 0) { %>
                <% products.forEach((product, index) => { 
                    const isHidden = index >= 16;
                %>
                    <div class="premium-card <%= isHidden ? 'premium-card-hidden' : '' %> wow fadeInUp" 
                         data-wow-duration="1s" 
                         data-wow-delay=".1s"
                         data-price="<%= product.price %>"
                         data-date="<%= product.createdAt ? product.createdAt.getTime() : 0 %>"
                         style="<%= isHidden ? 'display: none !important;' : '' %>">
                        <div class="premium-card-img-wrapper">
                            <a href="/product/<%= product._id %>">
                                <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="primary-img">
                                <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="secondary-img" style="filter: brightness(0.95);">
                            </a>
                            <button class="fav-btn"><i class="far fa-heart"></i></button>
                            <div class="card-actions">
                                <a href="/product/<%= product._id %>" class="btn-premium-secondary" style="padding: 10px; font-size: 10px;">İncele</a>
                                <button onclick="window.location.href='/product/<%= product._id %>'" class="btn-premium-primary" style="padding: 10px; font-size: 10px;">Sepete Ekle</button>
                            </div>
                        </div>
                        <div class="premium-card-info">
                            <div class="premium-card-title"><a href="/product/<%= product._id %>"><%= product.name %></a></div>
                            <div class="premium-card-desc"><%= product.description ? product.description.substring(0,30) + '...' : 'Pırlanta Şıklığı' %></div>
                            <div class="premium-card-price-wrap">
                                <span class="premium-card-price">₺ <%= product.price %></span>
                                <% if (product.price > 1000) { %>
                                    <span class="premium-card-old-price">₺ <%= Math.round(product.price * 1.2) %></span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div style="grid-column: 1 / -1; text-align: center; padding: 50px 0;">
                    <p style="font-size: 16px; color: #888;">Henüz ürün eklenmemiş.</p>
                </div>
            <% } %>
        </div>
        <!-- Expandable Show More Button -->
        <div class="row justify-content-center" style="margin-top: 40px; margin-bottom: 20px;">
            <div class="room-btn" id="showMoreContainer" style="<%= (typeof products !== 'undefined' && products.length <= 16) ? 'display: none;' : 'display: flex;' %>">
                <button id="btnShowMore" class="border-btn" style="background: transparent; cursor: pointer; border: 1px solid #c49b45; padding: 15px 35px; font-weight: bold; text-transform: uppercase; font-size: 12px; letter-spacing: 2px; transition: all 0.3s ease; border-radius: 4px;">Daha Fazla Göster</button>
            </div>
        </div>
    </div>
</div>
<!--? New Arrival End -->

<!--? Dinamik Özel Reyonlar Başlangıcı -->
<% if (typeof sections !== 'undefined' && sections.length > 0) { %>
    <% sections.forEach(sec => { %>
        <% if (sec.products && sec.products.length > 0) { %>
        <div class="new-arrival dynamic-section pt-50 pb-50" style="border-top: 1px solid rgba(0,0,0,0.03);">
            <div class="container">
                <div class="row justify-content-center mb-40">
                    <div class="col-xl-7 col-lg-8 col-md-10 text-center">
                        <div class="section-tittle mb-20 wow fadeInUp" data-wow-duration="2s" data-wow-delay=".2s">
                            <h2><%= sec.title %></h2>
                        </div>
                    </div>
                </div>
                <div class="premium-grid">
                    <% sec.products.forEach(product => { %>
                        <div class="premium-card wow fadeInUp" data-wow-duration="1s" data-wow-delay=".1s">
                            <div class="premium-card-img-wrapper">
                                <a href="/product/<%= product._id %>">
                                    <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="primary-img">
                                    <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="secondary-img" style="filter: brightness(0.95);">
                                </a>
                                <button class="fav-btn"><i class="far fa-heart"></i></button>
                                <div class="card-actions">
                                    <a href="/product/<%= product._id %>" class="btn-premium-secondary" style="padding: 10px; font-size: 10px;">İncele</a>
                                    <button onclick="window.location.href='/product/<%= product._id %>'" class="btn-premium-primary" style="padding: 10px; font-size: 10px;">Sepete Ekle</button>
                                </div>
                            </div>
                            <div class="premium-card-info">
                                <div class="premium-card-title"><a href="/product/<%= product._id %>"><%= product.name %></a></div>
                                <div class="premium-card-desc"><%= product.description ? product.description.substring(0,30) + '...' : 'Pırlanta Şıklığı' %></div>
                                <div class="premium-card-price-wrap">
                                    <span class="premium-card-price">₺ <%= product.price %></span>
                                    <% if (product.price > 1000) { %>
                                        <span class="premium-card-old-price">₺ <%= Math.round(product.price * 1.2) %></span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        </div>
        <% } %>
    <% }); %>
<% } %>
<!--? Dinamik Özel Reyonlar Bitişi -->

    <!--? Popular Items Start -->
    <div class="popular-items pt-50">
        <div class="container-fluid">
            <style>
                .col-fifth {
                    position: relative;
                    width: 100%;
                    padding-right: 15px;
                    padding-left: 15px;
                }
                @media (min-width: 992px) {
                    .col-fifth {
                        flex: 0 0 20%;
                        max-width: 20%;
                    }
                   <div class="row justify-content-center">
                <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                    <% categories.slice(0, 5).forEach((cat, index) => { 
                        let imgUrl = `/assets/img/gallery/popular${(index % 5) + 1}.png`;
                    %>
                        <div class="col-fifth col-md-4 col-sm-6">
                            <div class="single-popular-items mb-50 text-center wow fadeInUp" data-wow-duration="1s" data-wow-delay="<%= 0.1 * (index + 1) %>s">
                                <div class="popular-img">
                                    <img src="<%= imgUrl %>" alt="<%= cat.name %>" onerror="this.src='/assets/img/gallery/popular1.png'">
                                    <div class="img-cap">
                                        <span><%= cat.name %></span>
                                    </div>
                                    <div class="favorit-items">
                                        <a href="/shop?category=<%= cat.slug %>" class="btn">İncele</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="col-fifth col-md-4 col-sm-6">
                        <div class="single-popular-items mb-50 text-center">
                            <div class="popular-img">
                                <img src="/assets/img/gallery/popular1.png" alt="">
                                <div class="img-cap"><span>Pırlanta Yüzükler</span></div>
                                <div class="favorit-items"><a href="/shop?category=yuzukler" class="btn">İncele</a></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-fifth col-md-4 col-sm-6">
                        <div class="single-popular-items mb-50 text-center">
                            <div class="popular-img">
                                <img src="/assets/img/gallery/popular2.png" alt="" onerror="this.src='/assets/img/gallery/popular1.png'">
                                <div class="img-cap"><span>Pırlanta Kolyeler</span></div>
                                <div class="favorit-items"><a href="/shop?category=kolyeler" class="btn">İncele</a></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-fifth col-md-4 col-sm-6">
                        <div class="single-popular-items mb-50 text-center">
                            <div class="popular-img">
                                <img src="/assets/img/gallery/popular3.png" alt="" onerror="this.src='/assets/img/gallery/popular1.png'">
                                <div class="img-cap"><span>Pırlanta Küpeler</span></div>
                                <div class="favorit-items"><a href="/shop?category=kupeler" class="btn">İncele</a></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-fifth col-md-4 col-sm-6">
                        <div class="single-popular-items mb-50 text-center">
                            <div class="popular-img">
                                <img src="/assets/img/gallery/popular4.png" alt="" onerror="this.src='/assets/img/gallery/popular1.png'">
                                <div class="img-cap"><span>Pırlanta Bileklikler</span></div>
                                <div class="favorit-items"><a href="/shop?category=bileklikler" class="btn">İncele</a></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-fifth col-md-4 col-sm-6">
                        <div class="single-popular-items mb-50 text-center">
                            <div class="popular-img">
                                <img src="/assets/img/gallery/popular5.png" alt="" onerror="this.src='/assets/img/gallery/popular1.png'">
                                <div class="img-cap"><span>Alyanslar</span></div>
                                <div class="favorit-items"><a href="/shop?category=alyanslar" class="btn">İncele</a></div>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    <!-- Popular Items End -->

<!--? collection -->
<% if (typeof middleBanners !== 'undefined' && middleBanners.length > 0) { %>
    <% middleBanners.forEach(banner => { %>
        <section class="collection section-bg2 section-padding30 section-over1 ml-15 mr-15" style="background-image: url('<%= banner.imageUrl %>'); background-size: cover; background-position: center;">
            <div class="container-fluid">
                <div class="row justify-content-center">
                    <div class="col-xl-7 col-lg-9">
                        <div class="single-question text-center">
                            <h2 class="wow fadeInUp" data-wow-duration="2s" data-wow-delay=".1s"><%= banner.title %></h2>
                            <a href="<%= banner.link %>" class="btn wow fadeInUp" data-wow-duration="2s" data-wow-delay=".4s"><%= banner.subtitle || 'Keşfet' %></a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    <% }); %>
<% } else { %>
    <section class="collection section-bg2 section-padding30 section-over1 ml-15 mr-15" data-background="/assets/img/gallery/section_bg01.png">
        <div class="container-fluid">
            <div class="row justify-content-center">
                <div class="col-xl-7 col-lg-9">
                    <div class="single-question text-center">
                        <h2 class="wow fadeInUp" data-wow-duration="2s" data-wow-delay=".1s">Eşsiz Koleksiyonlarımızla Tanışın</h2>
                        <a href="/about" class="btn wow fadeInUp" data-wow-duration="2s" data-wow-delay=".4s">Hakkımızda</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
<% } %>
<!-- End collection -->

<!--? Services Area Start -->
<div class="categories-area section-padding40 gray-bg">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-3 col-md-6 col-sm-6">
                <div class="single-cat mb-50 wow fadeInUp" data-wow-duration="1s" data-wow-delay=".2s">
                    <div class="cat-icon">
                        <img src="/assets/img/icon/services1.svg" alt="">
                    </div>
                    <div class="cat-cap">
                        <h5><%= typeof setting !== 'undefined' ? (setting.service1Title || 'Hızlı ve Ücretsiz Teslimat') : 'Hızlı ve Ücretsiz Teslimat' %></h5>
                        <p><%= typeof setting !== 'undefined' ? (setting.service1Desc || 'Tüm siparişlerde ücretsiz kargo') : 'Tüm siparişlerde ücretsiz kargo' %></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 col-sm-6">
                <div class="single-cat mb-50 wow fadeInUp" data-wow-duration="1s" data-wow-delay=".2s">
                    <div class="cat-icon">
                        <img src="/assets/img/icon/services2.svg" alt="">
                    </div>
                    <div class="cat-cap">
                        <h5><%= typeof setting !== 'undefined' ? (setting.service2Title || 'Güvenli Ödeme') : 'Güvenli Ödeme' %></h5>
                        <p><%= typeof setting !== 'undefined' ? (setting.service2Desc || 'PayTR ile %100 güvenli ödeme') : 'PayTR ile %100 güvenli ödeme' %></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 col-sm-6">
                <div class="single-cat mb-30 wow fadeInUp" data-wow-duration="1s" data-wow-delay=".4s">
                    <div class="cat-icon">
                        <img src="/assets/img/icon/services3.svg" alt="">
                    </div>
                    <div class="cat-cap">
                        <h5><%= typeof setting !== 'undefined' ? (setting.service3Title || 'Mağazamızı Ziyaret Edin') : 'Mağazamızı Ziyaret Edin' %></h5>
                        <p><%= typeof setting !== 'undefined' ? (setting.service3Desc || 'Kapalıçarşı mağazamızı ziyaret edebilirsiniz') : 'Kapalıçarşı mağazamızı ziyaret edebilirsiniz' %></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 col-sm-6">
                <div class="single-cat wow fadeInUp" data-wow-duration="1s" data-wow-delay=".5s">
                    <div class="cat-icon">
                        <img src="/assets/img/icon/services4.svg" alt="">
                    </div>
                    <div class="cat-cap">
                        <h5><%= typeof setting !== 'undefined' ? (setting.service4Title || 'Uzman Kadro Desteği') : 'Uzman Kadro Desteği' %></h5>
                        <p><%= typeof setting !== 'undefined' ? (setting.service4Desc || 'Uzman kadromuzla 7/24 destek vermeye hazırız') : 'Uzman kadromuzla 7/24 destek vermeye hazırız' %></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--? Services Area End -->
<style>
/* Custom CSS styling for premium sort dropdown and hidden items */
.premium-card-hidden {
    display: none !important;
}

#homeProductSort {
    background-color: #ffffff;
    color: #1a1a1a;
    border: 1px solid #c49b45;
    padding: 8px 20px;
    border-radius: 25px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    outline: none;
    box-shadow: 0 4px 10px rgba(196, 155, 69, 0.15);
    transition: all 0.3s ease;
}

#homeProductSort:hover {
    border-color: #1a1a1a;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
}

#btnShowMore:hover {
    background-color: #c49b45 !important;
    color: #ffffff !important;
    border-color: #c49b45 !important;
    box-shadow: 0 4px 15px rgba(196, 155, 69, 0.4);
    transform: translateY(-2px);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const grid = document.getElementById('homeProductGrid');
    const sortSelect = document.getElementById('homeProductSort');
    const btnShowMore = document.getElementById('btnShowMore');
    const showMoreContainer = document.getElementById('showMoreContainer');
    
    let visibleLimit = 16;
    
    function updateVisibility() {
        if (!grid) return;
        const cards = Array.from(grid.querySelectorAll('.premium-card'));
        cards.forEach((card, index) => {
            if (index < visibleLimit) {
                card.style.setProperty('display', 'block', 'important');
                card.classList.remove('premium-card-hidden');
            } else {
                card.style.setProperty('display', 'none', 'important');
                card.classList.add('premium-card-hidden');
            }
        });
        
        if (showMoreContainer) {
            if (visibleLimit >= cards.length) {
                showMoreContainer.style.setProperty('display', 'none', 'important');
            } else {
                showMoreContainer.style.setProperty('display', 'flex', 'important');
            }
        }
    }
    
    function sortProducts(sortBy) {
        if (!grid) return;
        const cards = Array.from(grid.querySelectorAll('.premium-card'));
        
        cards.sort((a, b) => {
            if (sortBy === 'price-asc') {
                return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
            } else if (sortBy === 'price-desc') {
                return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
            } else {
                // newest
                return parseFloat(b.dataset.date) - parseFloat(a.dataset.date);
            }
        });
        
        cards.forEach(card => grid.appendChild(card));
        
        visibleLimit = 16;
        updateVisibility();
    }
    
    if (sortSelect) {
        $(sortSelect).on('change', function() {
            sortProducts(this.value);
        });
    }
    
    if (btnShowMore) {
        btnShowMore.addEventListener('click', function() {
            visibleLimit += 16;
            updateVisibility();
        });
    }
    
    updateVisibility();
});
</script>
</main>

<%- include('partials/footer') %>
