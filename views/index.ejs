<%- include('partials/head') %>
<%- include('partials/header') %>

<main>
    <style>
        /* Hero ile altındaki bölüm arasındaki boşluğu azaltma */
        .new-arrival.hero-adjacent-section {
            padding-top: 15px !important;
        }

        .slider-area .single-slider.slider-height {
            min-height: 980px !important; /* Masaüstü boyutu büyütüldü */
        }

        @media (max-width: 1199px) {
            .slider-area .single-slider.slider-height {
                min-height: 850px !important;
            }
        }

        @media (max-width: 991px) {
            .slider-area {
                margin-top: 24px;
            }
            .slider-area .single-slider.slider-height {
                min-height: 750px !important; /* Tablet boyutu büyütüldü */
            }
        }

        @media (max-width: 767px) {
            .slider-area .single-slider.slider-height {
                min-height: auto !important;
                height: 124vw !important; /* Görsel en-boy oranına (928x1152 => ~1.24) göre tam uyum */
                background-size: cover !important;
                background-position: center center !important;
            }

            .slider-area .single-slider.hero-overly {
                background-image: url('/assets/img/hero/whatsapp_hero_mobile.jpeg') !important;
            }

            .slider-area .hero__caption {
                padding: 0 12px !important;
            }

            .slider-area .hero__caption h1 {
                font-size: 28px; /* Mobilde daha okunaklı ve dengeli bir yazı boyutu */
                line-height: 1.2;
                margin-bottom: 18px;
            }
        }

        @media (max-width: 575px) {
            .slider-area .single-slider.slider-height {
                min-height: auto !important;
                height: 124vw !important;
            }
            .slider-area .hero__caption h1 {
                font-size: 24px;
            }
        }
    </style>
    <!--? Hero Area Start-->
    <div class="container-fluid">
        <div class="slider-area">
            <div class="slider-active dot-style">
                <% if (typeof heroBanners !== 'undefined' && heroBanners.length > 0) { %>
                    <% heroBanners.forEach(banner => { %>
                        <div class="single-slider hero-overly slider-height d-flex align-items-center" style="background-image: url('<%= banner.imageUrl %>'); background-size: cover; background-position: center;">
                            <div class="container">
                                <div class="row justify-content-center">
                                    <div class="col-xl-8 col-lg-9">
                                        <!-- Hero Caption -->
                                        <div class="hero__caption">
                                            <h1><%- banner.title.replace(/\n/g, '<br>') %></h1>
                                            <a href="<%= banner.link %>" class="btn"><%= banner.subtitle || 'Şimdi Al' %></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <!-- Fallback if no banners -->
                    <div style="cursor: pointer; width: 100%; line-height: 0;" onclick="window.location.href='/shop'">
                        <picture>
                            <source media="(max-width: 767px)" srcset="/assets/img/hero/whatsapp_hero_mobile.jpeg">
                            <img src="/assets/img/hero/slider_1.png" alt="Açılışa Özel Kampanya" style="width: 100%; height: auto; display: block;">
                        </picture>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    <!-- End Hero -->

<!--? Services Area Start -->
<div class="categories-area gray-bg" style="padding: 35px 0; border-bottom: 1px solid rgba(0,0,0,0.05);">
    <div class="container">
        <style>
            .services-old-grid {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 0;
                text-align: center;
            }
            .service-old-item {
                display: flex;
                flex-direction: row;
                align-items: center;
                justify-content: center;
                padding: 20px 15px;
                border-right: 1px solid rgba(0,0,0,0.07);
            }
            .service-old-item:last-child {
                border-right: none;
            }
            .service-old-icon {
                margin-right: 14px;
                flex-shrink: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: transform 0.3s ease;
            }
            .service-old-item:hover .service-old-icon {
                transform: translateY(-3px);
            }
            .service-old-icon svg {
                width: 36px;
                height: 36px;
            }
            .service-old-text {
                text-align: left;
            }
            .service-old-title {
                font-family: 'Montserrat', sans-serif !important;
                font-size: 13px;
                font-weight: 600;
                color: #1a1a1a;
                line-height: 1.3;
                margin: 0 0 3px 0;
            }
            .service-old-desc {
                font-family: 'Montserrat', sans-serif !important;
                font-size: 11px;
                font-weight: 400;
                color: #777;
                line-height: 1.4;
                margin: 0;
            }
            @media (max-width: 991px) {
                .services-old-grid {
                    grid-template-columns: repeat(2, 1fr);
                }
                .service-old-item {
                    border-right: 1px solid rgba(0,0,0,0.07);
                    border-bottom: 1px solid rgba(0,0,0,0.07);
                }
                .service-old-item:nth-child(2n) {
                    border-right: none;
                }
                .service-old-item:nth-last-child(-n+2) {
                    border-bottom: none;
                }
            }
            @media (max-width: 575px) {
                .services-old-grid {
                    grid-template-columns: repeat(2, 1fr);
                }
                .service-old-item {
                    padding: 16px 10px;
                    flex-direction: column;
                    align-items: center;
                }
                .service-old-icon {
                    margin-right: 0;
                    margin-bottom: 8px;
                }
                .service-old-text {
                    text-align: center;
                }
                .service-old-title {
                    font-size: 11px;
                }
                .service-old-desc {
                    font-size: 10px;
                }
            }
        </style>
        <div class="services-old-grid">
            <!-- Item 1: Sigortalı Teslimat -->
            <div class="service-old-item wow fadeInUp" data-wow-duration="1s" data-wow-delay=".1s">
                <div class="service-old-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="3" width="15" height="13" rx="2" ry="2"/>
                        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                        <circle cx="5.5" cy="18.5" r="2.5"/>
                        <circle cx="18.5" cy="18.5" r="2.5"/>
                    </svg>
                </div>
                <div class="service-old-text">
                    <h5 class="service-old-title">Sigortalı Teslimat</h5>
                    <p class="service-old-desc">Güvenli ve hızlı kargo</p>
                </div>
            </div>

            <!-- Item 2: Güvenli Ödeme -->
            <div class="service-old-item wow fadeInUp" data-wow-duration="1s" data-wow-delay=".2s">
                <div class="service-old-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                        <line x1="1" y1="10" x2="23" y2="10"/>
                    </svg>
                </div>
                <div class="service-old-text">
                    <h5 class="service-old-title">Güvenli Ödeme</h5>
                    <p class="service-old-desc">256-bit SSL şifreleme</p>
                </div>
            </div>

            <!-- Item 3: Kolay İade -->
            <div class="service-old-item wow fadeInUp" data-wow-duration="1s" data-wow-delay=".3s">
                <div class="service-old-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
                        <path d="M3 3v5h5"/>
                    </svg>
                </div>
                <div class="service-old-text">
                    <h5 class="service-old-title">Kolay İade</h5>
                    <p class="service-old-desc">14 gün iade garantisi</p>
                </div>
            </div>

            <!-- Item 4: Uzman Destek -->
            <div class="service-old-item wow fadeInUp" data-wow-duration="1s" data-wow-delay=".4s">
                <div class="service-old-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.4 2 2 0 0 1 3.57 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.76a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.03z"/>
                    </svg>
                </div>
                <div class="service-old-text">
                    <h5 class="service-old-title">Uzman Destek</h5>
                    <p class="service-old-desc">7/24 müşteri hizmetleri</p>
                </div>
            </div>
        </div>
    </div>
</div>
<!--? Services Area End -->

<!--? New Arrival Start -->
<div class="new-arrival">
    <div class="container">
        <!-- Section title & Sorting Dropdown -->
        <div class="row justify-content-center mb-40">
            <div class="col-xl-7 col-lg-8 col-md-10 text-center">
                <div class="section-tittle mb-20 wow fadeInUp" data-wow-duration="2s" data-wow-delay=".2s">
                    <h2><%= typeof setting !== 'undefined' ? (setting.newArrivalTitle || 'Yeni Gelenler') : 'Yeni Gelenler' %></h2>
                </div>
                <!-- Premium Sorting Dropdown -->
                <div class="sorting-wrapper wow fadeInUp" data-wow-duration="1.5s" data-wow-delay=".3s">
                    <label for="homeProductSort">Sıralama:</label>
                    <select id="homeProductSort">
                        <option value="newest" selected>En Yeniler (Varsayılan)</option>
                        <option value="price-asc">Fiyat: Düşükten Yükseğe</option>
                        <option value="price-desc">Fiyat: Yüksekten Düşüğe</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="premium-grid" id="homeProductGrid">
            <% if (typeof products !== 'undefined' && products.length > 0) { %>
                <% products.forEach((product, index) => { 
                    const isHidden = index >= 16;
                %>
                    <div class="premium-card <%= isHidden ? 'premium-card-hidden' : '' %> wow fadeInUp" 
                         data-wow-duration="1s" 
                         data-wow-delay=".1s"
                         data-price="<%= product.price %>"
                         data-date="<%= product.createdAt ? product.createdAt.getTime() : 0 %>"
                         style="<%= isHidden ? 'display: none !important;' : '' %>">
                        <div class="premium-card-img-wrapper">
                            <a href="/product/<%= product._id %>">
                                <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="primary-img">
                                <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="secondary-img" style="filter: brightness(0.95);">
                            </a>
                            <button class="fav-btn" data-id="<%= product._id %>">
                                <i class="<%= (typeof userFavorites !== 'undefined' && userFavorites.includes(product._id.toString())) ? 'fas fa-heart text-danger' : 'far fa-heart' %>"></i>
                            </button>
                        </div>
                        <div class="premium-card-info">
                            <div class="premium-card-title"><a href="/product/<%= product._id %>"><%= product.name %></a></div>
                            <div class="premium-card-desc"><%= product.description ? product.description.substring(0,30) + '...' : 'Pırlanta Şıklığı' %></div>
                            <div class="premium-card-price-wrap">
                                <span class="premium-card-price">₺ <%= product.price.toLocaleString('tr-TR') %></span>
                                <% if (product.price > 1000) { %>
                                    <span class="premium-card-old-price">₺ <%= Math.round(product.price * 1.2).toLocaleString('tr-TR') %></span>
                                <% } %>
                            </div>
                            <div class="card-actions">
                                <a href="/product/<%= product._id %>" class="btn-premium-secondary" style="padding: 10px; font-size: 10px;">İncele</a>
                                <button onclick="window.location.href='/product/<%= product._id %>'" class="btn-premium-primary" style="padding: 10px; font-size: 10px;">Sepete Ekle</button>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div style="grid-column: 1 / -1; text-align: center; padding: 50px 0;">
                    <p style="font-size: 16px; color: #888;">Henüz ürün eklenmemiş.</p>
                </div>
            <% } %>
        </div>
        <!-- Expandable Show More Button -->
        <div class="row justify-content-center" style="margin-top: 40px; margin-bottom: 20px;">
            <div class="room-btn" id="showMoreContainer" style="<%= (typeof products !== 'undefined' && products.length <= 16) ? 'display: none;' : 'display: flex;' %>">
                <button id="btnShowMore" class="border-btn" style="background: transparent; cursor: pointer; border: 1px solid #c49b45; padding: 15px 35px; font-weight: bold; text-transform: uppercase; font-size: 12px; letter-spacing: 2px; transition: all 0.3s ease; border-radius: 4px;">Daha Fazla Göster</button>
            </div>
        </div>
    </div>
</div>
<!--? New Arrival End -->

<!--? Dinamik Özel Reyonlar Başlangıcı -->
<% if (typeof sections !== 'undefined' && sections.length > 0) { %>
    <% sections.forEach(sec => { %>
        <% if (sec.products && sec.products.length > 0) { %>
        <div class="new-arrival dynamic-section pt-50 pb-50" style="border-top: 1px solid rgba(0,0,0,0.03);">
            <div class="container">
                <div class="row justify-content-center mb-40">
                    <div class="col-xl-7 col-lg-8 col-md-10 text-center">
                        <div class="section-tittle mb-20 wow fadeInUp" data-wow-duration="2s" data-wow-delay=".2s">
                            <h2><%= sec.title %></h2>
                        </div>
                    </div>
                </div>
                <div class="premium-grid">
                    <% sec.products.forEach(product => { %>
                        <div class="premium-card wow fadeInUp" data-wow-duration="1s" data-wow-delay=".1s">
                            <div class="premium-card-img-wrapper">
                                <a href="/product/<%= product._id %>">
                                    <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="primary-img">
                                    <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="secondary-img" style="filter: brightness(0.95);">
                                </a>
                                <button class="fav-btn" data-id="<%= product._id %>">
                                    <i class="<%= (typeof userFavorites !== 'undefined' && userFavorites.includes(product._id.toString())) ? 'fas fa-heart text-danger' : 'far fa-heart' %>"></i>
                                </button>
                            </div>
                            <div class="premium-card-info">
                                <div class="premium-card-title"><a href="/product/<%= product._id %>"><%= product.name %></a></div>
                                <div class="premium-card-desc"><%= product.description ? product.description.substring(0,30) + '...' : 'Pırlanta Şıklığı' %></div>
                                <div class="premium-card-price-wrap">
                                    <span class="premium-card-price">₺ <%= product.price.toLocaleString('tr-TR') %></span>
                                    <% if (product.price > 1000) { %>
                                        <span class="premium-card-old-price">₺ <%= Math.round(product.price * 1.2).toLocaleString('tr-TR') %></span>
                                    <% } %>
                                </div>
                                <div class="card-actions">
                                    <a href="/product/<%= product._id %>" class="btn-premium-secondary" style="padding: 10px; font-size: 10px;">İncele</a>
                                    <button onclick="window.location.href='/product/<%= product._id %>'" class="btn-premium-primary" style="padding: 10px; font-size: 10px;">Sepete Ekle</button>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        </div>
        <% } %>
    <% }); %>
<% } %>
<!--? Dinamik Özel Reyonlar Bitişi -->

<style>
/* Custom CSS styling for premium sort dropdown and hidden items */
.premium-card-hidden {
    display: none !important;
}


#btnShowMore:hover {
    background-color: #c49b45 !important;
    color: #ffffff !important;
    border-color: #c49b45 !important;
    box-shadow: 0 4px 15px rgba(196, 155, 69, 0.4);
    transform: translateY(-2px);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const grid = document.getElementById('homeProductGrid');
    const sortSelect = document.getElementById('homeProductSort');
    const btnShowMore = document.getElementById('btnShowMore');
    const showMoreContainer = document.getElementById('showMoreContainer');
    
    let visibleLimit = 16;
    
    function updateVisibility() {
        if (!grid) return;
        const cards = Array.from(grid.querySelectorAll('.premium-card'));
        cards.forEach((card, index) => {
            if (index < visibleLimit) {
                card.style.setProperty('display', 'block', 'important');
                card.classList.remove('premium-card-hidden');
            } else {
                card.style.setProperty('display', 'none', 'important');
                card.classList.add('premium-card-hidden');
            }
        });
        
        if (showMoreContainer) {
            if (visibleLimit >= cards.length) {
                showMoreContainer.style.setProperty('display', 'none', 'important');
            } else {
                showMoreContainer.style.setProperty('display', 'flex', 'important');
            }
        }
    }
    
    function sortProducts(sortBy) {
        if (!grid) return;
        const cards = Array.from(grid.querySelectorAll('.premium-card'));
        
        cards.sort((a, b) => {
            if (sortBy === 'price-asc') {
                return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
            } else if (sortBy === 'price-desc') {
                return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
            } else {
                // newest
                return parseFloat(b.dataset.date) - parseFloat(a.dataset.date);
            }
        });
        
        cards.forEach(card => grid.appendChild(card));
        
        visibleLimit = 16;
        updateVisibility();
    }
    
    if (sortSelect) {
        $(sortSelect).on('change', function() {
            sortProducts(this.value);
        });
    }
    
    if (btnShowMore) {
        btnShowMore.addEventListener('click', function() {
            visibleLimit += 16;
            updateVisibility();
        });
    }
    
    updateVisibility();
});
</script>
</main>

<%- include('partials/footer') %>
