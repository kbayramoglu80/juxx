<%- include('partials/head') %>
<%- include('partials/header') %>

<main>
    <div class="slider-area ">
        <div class="single-slider slider-height2 d-flex align-items-center">
            <div class="container">
                <div class="row">
                    <div class="col-xl-12">
                        <div class="hero-cap text-center">
                            <h2>PayTR Debug</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <section class="section_padding">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <h3>Sistem Durumu</h3>
                    <div class="card mb-4">
                        <div class="card-body">
                            <p><strong>Sunucu Durumu:</strong> <%= debugInfo.server_status %></p>
                            <p><strong>Zaman:</strong> <%= debugInfo.timestamp %></p>
                            <p><strong>Callback Endpoint:</strong> <%= debugInfo.endpoint %></p>
                            <p><strong>Bildirim URL:</strong> <%= debugInfo.notification_url %></p>
                        </div>
                    </div>

                    <h3>Çevre Değişkenleri</h3>
                    <div class="card mb-4">
                        <div class="card-body">
                            <ul>
                                <li>PAYTR_MERCHANT_ID: <%= debugInfo.env_check.PAYTR_MERCHANT_ID %></li>
                                <li>PAYTR_MERCHANT_KEY: <%= debugInfo.env_check.PAYTR_MERCHANT_KEY %></li>
                                <li>PAYTR_MERCHANT_SALT: <%= debugInfo.env_check.PAYTR_MERCHANT_SALT %></li>
                                <li>NODE_ENV: <%= debugInfo.env_check.NODE_ENV %></li>
                                <li>MONGODB_URI: <%= debugInfo.env_check.MONGODB_URI %></li>
                            </ul>
                        </div>
                    </div>

                    <h3>Test Talimatları</h3>
                    <div class="card mb-4">
                        <div class="card-body">
                            <ol>
                                <% debugInfo.test_instructions.forEach((instruction, index) => { %>
                                    <li><%= instruction %></li>
                                <% }); %>
                            </ol>
                        </div>
                    </div>

                    <h3>En Yaygın Sorunlar ve Çözümler</h3>
                    <div class="card">
                        <div class="card-body">
                            <h5>Sorun 1: Yönlendirme (Redirect) Sorunu</h5>
                            <p>Eğer siteniz HTTP'den HTTPS'ye veya www'den non-www'ye otomatik yönlendirme yapıyorsa, PayTR'nin POST isteği GET'e dönüşür ve veri kaybolur.</p>
                            <p><strong>Çözüm:</strong> PayTR panelindeki Bildirim URL'sini <strong>nihai URL</strong> olarak ayarlayın (yönlendirme yapmayan). Örnek: <code>https://www.midiamond.com.tr/payment/callback</code></p>

                            <h5>Sorun 2: .env Dosyası Eksik</h5>
                            <p>Sunucunuzda .env dosyasının olduğundan ve doğru bilgileri içerdiğinden emin olun.</p>
                            <p><strong>Çözüm:</strong> .env dosyasını kontrol edin ve şu bilgileri ekleyin:</p>
                            <pre>
PAYTR_MERCHANT_ID=mağaza_id_niz
PAYTR_MERCHANT_KEY=mağaza_anahtarınız
PAYTR_MERCHANT_SALT=mağaza_tuzunuz
NODE_ENV=production
                            </pre>

                            <h5>Sorun 3: Firewall/Güvenlik Duvarı</h5>
                            <p>Güvenlik duvarı PayTR'nin sunucusundan gelen istekleri engelliyor olabilir.</p>
                            <p><strong>Çözüm:</strong> PayTR IP adreslerini güvenlik duvarınızda izin verilenler listesine ekleyin.</p>
                        </div>
                    </div>

                    <div class="mt-4 text-center">
                        <a href="/payment/test" class="btn_1">Test Endpoint'ini Aç</a>
                        <a href="/" class="btn_3">Ana Sayfaya Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
